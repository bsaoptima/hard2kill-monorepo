# Copy to .env next to docker-compose.yml and fill in real values.

# ── Deployment ────────────────────────────────────────────────────────────
DROPLET_IP=161.35.99.157
VALVE_ZIP=/root/valve-dust2.v1.zip

# ── Wagering ──────────────────────────────────────────────────────────────
# Where the sidecar POSTs signed match results.
MATCH_WEBHOOK_URL=https://hard2kill.com/api/cs16/match-result

# Shared HMAC secret. MUST be IDENTICAL on both ends:
#   - this droplet's .env
#   - hard2kill.com's Railway env (variable: CS16_WEBHOOK_SECRET)
# Generate a fresh one with: ./scripts/gen-secret.sh --write .env
# Then mirror the value into Railway's environment variables manually.
CS16_WEBHOOK_SECRET=replace-me
