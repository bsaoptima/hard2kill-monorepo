# Copy to .env on the droplet and fill in real values.
#
# H2K_WEBHOOK_URL — where the sidecar POSTs signed match results.
#   Production: https://h2k.app/api/cs16/match-result
#   Dev:        http://host.docker.internal:3001/api/cs16/match-result
H2K_WEBHOOK_URL=https://h2k.app/api/cs16/match-result

# CS16_WEBHOOK_SECRET — shared HMAC secret. Must be IDENTICAL to the value
# set on the H2K backend. Generate with: ./scripts/gen-secret.sh
CS16_WEBHOOK_SECRET=replace-me
